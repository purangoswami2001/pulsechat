# Server Settings
PORT=8080
ENV=development

# Database Settings
DB_DSN=postgres://postgres:postgres@localhost:5432/pulsechat?sslmode=disable

# Redis Settings
REDIS_URL=redis://localhost:6379/0

# PubSub Settings
PUBSUB_DRIVER=memory

# Authentication Settings
JWT_SECRET=super_secret_jwt_key_should_be_long_and_random
JWT_EXPIRATION_HOURS=24
